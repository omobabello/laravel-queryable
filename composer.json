{
    "name": "omoba/laravel-queryable",
    "description": "Declarative search, sort, and filter scopes for Eloquent models — with relationship traversal.",
    "keywords": ["laravel", "eloquent", "search", "filter", "sort", "query-builder"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Omoba Bello",
            "email": "omobello07@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.5|^11.0",
        "larastan/larastan": "^2.9|^3.0",
        "laravel/pint": "^1.13"
    },
    "autoload": {
        "psr-4": {
            "Omoba\\LaravelQueryable\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Omoba\\LaravelQueryable\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Omoba\\LaravelQueryable\\LaravelQueryableServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "stan": "vendor/bin/phpstan analyse --memory-limit=1G",
        "pint": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
